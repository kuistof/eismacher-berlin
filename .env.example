# Die Eismacher — Meta-Konfiguration (VORLAGE, ohne Geheimnisse)
# Kopiere diese Datei nach ".env" und trage dort den Token ein.
# WICHTIG: ".env" ist über .gitignore ausgeschlossen und darf NIE committet werden.

# Öffentlich (steht ohnehin im Client-Code) — Browser-Pixel
META_PIXEL_ID=1338725961680394

# GEHEIM — nur serverseitig verwenden (Serverless-Funktion / Vercel-Env),
# niemals im Client-Code oder im öffentlichen Repo.
META_CAPI_ACCESS_TOKEN=

# Optional: Test-Event-Code aus dem Events-Manager (zum Debuggen der CAPI)
META_TEST_EVENT_CODE=
